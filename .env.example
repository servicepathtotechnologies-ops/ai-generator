# ── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── LLM ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Auth — shared with worker for Cognito token verification ─────────────────
AWS_REGION=
COGNITO_USER_POOL_ID=
COGNITO_ISSUER=

# ── Worker — for node catalog fetch & internal service-to-service auth ───────
WORKER_URL=http://localhost:3001
# Must match AI_GENERATOR_SERVICE_KEY in worker .env
AI_GENERATOR_SERVICE_KEY=

# ── Redis — shared cache (optional; catalog falls back to worker HTTP if absent)
REDIS_URL=
